# API (local `npm run dev` / self-hosted `npm start`; on Vercel set JWT_SECRET in project env vars)
PORT=4000
JWT_SECRET=replace-with-a-long-random-secret
# DATABASE_URL=postgresql://user:password@localhost:5432/child_compass

# Web build for native mobile/desktop shells: point at your deployed API origin.
# VITE_API_URL=https://your-app.vercel.app

# Desktop shell (apps/desktop): URL the Electron window loads.
# COMPASS_APP_URL=https://your-app.vercel.app
