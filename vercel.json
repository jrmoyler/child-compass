{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "npm install",
  "buildCommand": "npm run build:web && node scripts/bundle-api.mjs",
  "outputDirectory": "apps/web/dist",
  "functions": {
    "api/index.mjs": { "maxDuration": 10 }
  },
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/index" },
    { "source": "/((?!api/|assets/|icons/|sw\\.js|manifest\\.webmanifest|garden-moment\\.svg).*)", "destination": "/index.html" }
  ]
}
